# Copy to ".env" for local development only (never commit .env).
#
# All secrets are user-provided. The package does not ship bundled API keys
# or Telegram credentials in wheels.

BURN_TELEGRAM_BOT_TOKEN=
BURN_TELEGRAM_CHAT_ID=
TAOSTATS_API_KEY=
TAOSTATS_API_BASE=https://api.taostats.io
BURN_ALERT_THRESHOLD=0.1
BURN_WATCH_INTERVAL_MINUTES=30
