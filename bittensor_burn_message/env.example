# User config — written to your data directory on first run.
# All credentials are yours; nothing is bundled in the package wheel.
#
# Configure via install, e.g.:
#   bittensor-burn-message install \
#     --telegram_token TOKEN \
#     --telegram_chat_id CHAT_ID \
#     --taostats_api_key KEY

# --- Burn rate monitoring (your Telegram bot) ---
BURN_TELEGRAM_BOT_TOKEN=
BURN_TELEGRAM_CHAT_ID=
BURN_ALERT_THRESHOLD=0.1
BURN_WATCH_INTERVAL_MINUTES=30

# --- Taostats API (your key from https://taostats.io) ---
TAOSTATS_API_KEY=
TAOSTATS_API_BASE=https://api.taostats.io
